---
layout: layouts/base.njk
title: Casi di studio
description: Casi di studio di MysteryClient.it — progetti di mystery shopping, customer experience e retail.
permalink: "/casi-di-studio/"
---

<!-- Start Page Banner -->
<section class="page-banner">
    <div class="content-width">
        <div class="page-banner-content">
            <h1>Casi di studio</h1>
            <div class="breadcrumb">
                <a href="/">Home</a> &rsaquo; Casi di studio
            </div>
        </div>
    </div>
</section>
<!-- End Page Banner -->

<!-- Start Portfolio Listing -->
<section class="portfolio-listing-section">
    <div class="content-width">
        <!-- Category Filters -->
        <div class="portfolio-filters">
            <button class="portfolio-filter active" data-filter="all">All</button>
            {% for cat in collections.portfolioCategories %}
            <button class="portfolio-filter" data-filter="{{ cat | slugify }}">{{ cat }}</button>
            {% endfor %}
        </div>

        <!-- Portfolio Grid -->
        <div class="portfolio-grid">
            {% for item in collections.caseStudies %}
            <div class="portfolio-item" data-categories="{% for cat in item.data.categories %}{{ cat | slugify }}{% if not loop.last %} {% endif %}{% endfor %}">
                <div class="portfolio-item-image">
                    {% if item.data.image %}
                    <img src="{{ item.data.image }}" alt="{{ item.data.title }}" loading="lazy">
                    {% endif %}
                    <div class="blog-related-overlay">
                        <div class="blog-card-overlay-icons">
                            <a href="{{ item.url }}" class="blog-card-overlay-icon flex-center" aria-label="View project">
                                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M10 13a5 5 0 007.54.54l3-3a5 5 0 00-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 00-7.54-.54l-3 3a5 5 0 007.07 7.07l1.71-1.71"/></svg>
                            </a>
                            {% if item.data.image %}
                            <button class="blog-card-overlay-icon lightbox-trigger flex-center" data-image="{{ item.data.image }}" aria-label="View image">
                                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
                            </button>
                            {% endif %}
                        </div>
                    </div>
                </div>
                <p class="blog-card-excerpt">{{ item.templateContent | excerpt(9) }} <a href="{{ item.url }}" class="link-secondary">[...]</a></p>
            </div>
            {% endfor %}
        </div>
    </div>
</section>
<!-- End Portfolio Listing -->
