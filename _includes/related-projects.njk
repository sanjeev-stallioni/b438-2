{% if resolvedRelatedProjects and resolvedRelatedProjects.length > 0 %}
<div class="blog-related-posts">
    <h3 class="blog-related-title">Related Projects</h3>
    <div class="blog-related-grid">
        {% for rp in resolvedRelatedProjects %}
        <div class="blog-related-item">
            {% if rp.image %}
            <img src="{{ rp.image }}" alt="{{ rp.title }}" loading="lazy">
            {% endif %}
            <div class="blog-related-overlay">
                <div class="blog-card-overlay-icons">
                    <a href="{{ rp.url }}" class="blog-card-overlay-icon flex-center" aria-label="View project">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M10 13a5 5 0 007.54.54l3-3a5 5 0 00-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 00-7.54-.54l-3 3a5 5 0 007.07 7.07l1.71-1.71"/></svg>
                    </a>
                    {% if rp.image %}
                    <button class="blog-card-overlay-icon lightbox-trigger flex-center" data-image="{{ rp.image }}" aria-label="View image">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
                    </button>
                    {% endif %}
                </div>
                <p class="blog-card-overlay-title">{{ rp.title }}</p>
            </div>
        </div>
        {% endfor %}
    </div>
</div>
{% endif %}
