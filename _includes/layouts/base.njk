<!DOCTYPE html>
<html lang="it">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1">

    <!-- Page Title -->
    <title>{{ title }} | MysteryClient.it</title>

    <!-- Meta Description -->
    <meta name="description" content="{{ description or 'Blog di MysteryClient.it — articoli su mystery shopping, customer experience e retail.' }}">

    <!-- Open Graph -->
    <meta property="og:locale" content="it_IT">
    <meta property="og:type" content="article">
    <meta property="og:title" content="{{ title }}">
    <meta property="og:description" content="{{ description or '' }}">
    <meta property="og:url" content="https://mysteryclient.it{{ page.url }}">
    <meta property="og:site_name" content="MysteryClient.it">

    <!-- Canonical -->
    <link rel="canonical" href="https://mysteryclient.it{{ page.url }}">

    <!-- Favicon -->
    <link rel="shortcut icon" type="image/x-icon" href="/assets/images/favicon.png">
    <link rel="apple-touch-icon" sizes="180x180" href="/assets/images/favicon.png">
    <link rel="icon" sizes="192x192" href="/assets/images/favicon.png">

    <!-- CSS -->
    <link rel="stylesheet" href="/assets/css/common.css">
    <link rel="stylesheet" href="/assets/css/blog.css">
</head>
<body>
    <!-- Start Header -->
    <header class="site-header">
        <div class="app-container">
            <nav class="navbar">
                <a href="/" class="logo">
                    <img src="/assets/images/logo.png" alt="MysteryClient.it">
                </a>

                <button class="mobile-toggle" aria-label="Toggle menu">
                    <span></span>
                    <span></span>
                    <span></span>
                </button>

                <ul class="nav-menu">
                    <li><a href="/" class="nav-link">Home</a></li>
                    {% set isMCSection = '/chi-siamo' in page.url or '/cose-il-mystery-client' in page.url or '/il-metodo-mebius' in page.url or '/persone-speciali' in page.url or '/mystery-software' in page.url or '/casi-di-studio' in page.url or '/portfolio-items/' in page.url or '/mystery-marketing-news' in page.url %}
                    <li class="has-dropdown">
                        <a href="#" class="nav-link{% if isMCSection %} active{% endif %}">MYSTERY CLIENT <svg class="chevron-icon" width="10" height="6" viewBox="0 0 10 6" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M1 1L5 5L9 1" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg></a>
                        <ul class="dropdown">
                            <li><a href="/chi-siamo"{% if '/chi-siamo' in page.url %} class="active"{% endif %}>CHI SIAMO</a></li>
                            <li><a href="/cose-il-mystery-client"{% if '/cose-il-mystery-client' in page.url %} class="active"{% endif %}>COS'E' IL MC</a></li>
                            <li><a href="/il-metodo-mebius"{% if '/il-metodo-mebius' in page.url %} class="active"{% endif %}>IL METODO MEBIUS</a></li>
                            <li><a href="/persone-speciali"{% if '/persone-speciali' in page.url %} class="active"{% endif %}>PERSONE SPECIALI</a></li>
                            <li><a href="/mystery-software"{% if '/mystery-software' in page.url %} class="active"{% endif %}>MYSTERY SOFTWARE</a></li>
                            <li><a href="/casi-di-studio/"{% if '/casi-di-studio' in page.url or '/portfolio-items/' in page.url %} class="active"{% endif %}>CASI DI STUDIO</a></li>
                            <li><a href="/mystery-marketing-news"{% if '/mystery-marketing-news' in page.url %} class="active"{% endif %}>Mystery Marketing News</a></li>
                        </ul>
                    </li>
                    <li class="has-dropdown">
                        <a href="/servizi/" class="nav-link">SERVIZI <svg class="chevron-icon" width="10" height="6" viewBox="0 0 10 6" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M1 1L5 5L9 1" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg></a>
                        <ul class="dropdown">
                            <li><a href="/mystery-client/">Mystery Client</a></li>
                            <li><a href="/voice-of-customer/">Voice of Customer</a></li>
                            <li><a href="#">Business Intelligence</a></li>
                            <li><a href="#">Mystery Automotive</a></li>
                            <li class="has-subdropdown">
                                <a href="#">ALTRI SERVIZI <svg class="chevron-icon" width="8" height="5" viewBox="0 0 10 6" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M1 1L5 5L9 1" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg></a>
                                <ul class="subdropdown">
                                    <li><a href="#">RICERCHE DI MERCATO</a></li>
                                    <li><a href="#">SALA PER FOCUS GROUP</a></li>
                                </ul>
                            </li>
                        </ul>
                    </li>
                    <li><a href="/blog/" class="nav-link{% if '/blog' in page.url %} active{% endif %}">Blog</a></li>
                    <li class="has-dropdown">
                        <a href="#" class="nav-link">DIVENTA MYSTERY CLIENT <svg class="chevron-icon" width="10" height="6" viewBox="0 0 10 6" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M1 1L5 5L9 1" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg></a>
                        <ul class="dropdown">
                            <li><a href="#">Mystery Client Academy</a></li>
                        </ul>
                    </li>
                    <li class="nav-cta">
                        <a href="/contatti/" class="btn-base btn-primary-rounded">CONTATTI</a>
                    </li>
                    <li class="mobile-display"><a href="/contatti/" class="nav-link">CONTATTI</a></li>
                    <li class="has-dropdown">
                        <a href="#" class="nav-link">Login <svg class="chevron-icon" width="10" height="6" viewBox="0 0 10 6" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M1 1L5 5L9 1" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg></a>
                        <ul class="dropdown right-0">
                            <li><a href="#">Sei un cliente?</a></li>
                            <li><a href="#">Sei uno shopper?</a></li>
                        </ul>
                    </li>
                </ul>
            </nav>
        </div>
    </header>
    <!-- End Header -->

    <!-- Start Main Content -->
    <main>
        {{ content | safe }}
    </main>
    <!-- End Main Content -->

    <!-- Start Footer -->
    <footer class="site-footer">
        <div class="footer-bottom">
            <div class="app-container">
                <div class="footer-bottom-top">
                    <a href="/" class="footer-logo">
                        <img src="/assets/images/logo-white.png" alt="MysteryClient.it">
                    </a>
                    <div class="footer-social">
                        <a href="https://www.facebook.com/mysteryclient.it/" class="social-icon flex-center" target="_blank" aria-label="Facebook">
                            <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
                        </a>
                        <a href="https://www.linkedin.com/company/15174656/" class="social-icon flex-center" target="_blank" aria-label="LinkedIn">
                            <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
                        </a>
                    </div>
                </div>

                <div class="footer-tags">
                    <span class="tags-label">TAG</span>
                    <div class="tags-list">
                        <a href="#">clienti</a>
                        <a href="#">dipendenti</a>
                        <a href="#">fidelity</a>
                        <a href="#">intelligenza artificiale</a>
                        <a href="#">retail</a>
                        <a href="#">servizio clienti</a>
                        <a href="#">supporto clienti</a>
                    </div>
                </div>

                <div class="footer-copyright">
                    <p>&copy; Copyright 2018 - 2026 | MysteryClient.it &egrave; un prodotto <a href="http://www.mebius.it/" target="_blank">Mebius srl</a> | Sede Legale Via L'Aquila 23/m Roma | P.I. e C.F. 08694131007 Capitale Sociale &euro; 10.000 i.v.</p>
                    <p>Pec Mebius@pec.it | Rea Roma n&deg; 1112940/2005 | Codice SdI M5UXCR1 | <a href="/">Privacy</a></p>
                </div>
            </div>
        </div>
    </footer>
    <!-- End Footer -->

    <!-- Start Fixed Icons -->
    <div class="fixed-icons">
        <a href="#" class="fixed-icon scroll-top flex-center" id="scrollTopBtn" aria-label="Scroll to top">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M18 15L12 9L6 15" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </a>
        <a href="tel:390690289181" class="fixed-icon phone-icon flex-center" aria-label="Call us">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor" xmlns="http://www.w3.org/2000/svg"><path d="M6.62 10.79a15.053 15.053 0 006.59 6.59l2.2-2.2a1.003 1.003 0 011.01-.24c1.12.37 2.33.57 3.57.57.55 0 1 .45 1 1V20c0 .55-.45 1-1 1C10.07 21 3 13.93 3 4c0-.55.45-1 1-1h3.5c.55 0 1 .45 1 1 0 1.25.2 2.45.57 3.57.1.31.03.66-.25 1.02l-2.2 2.2z"/></svg>
        </a>
    </div>
    <!-- End Fixed Icons -->

    <!-- Blog Lightbox -->
    <div class="lightbox" id="blogLightbox">
        <button class="lightbox-close" aria-label="Close">&times;</button>
        <button class="lightbox-prev flex-center" aria-label="Previous">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 18l-6-6 6-6"/></svg>
        </button>
        <div class="lightbox-content">
            <img src="" alt="" class="lightbox-img">
        </div>
        <button class="lightbox-next flex-center" aria-label="Next">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 18l6-6-6-6"/></svg>
        </button>
    </div>

    <!-- Main Javascript -->
    <script src="/assets/js/script.js"></script>
    <script src="/assets/js/lightbox.js"></script>
    <script src="/assets/js/blog-scroll.js"></script>
    <script src="/assets/js/portfolio-filter.js"></script>
</body>
</html>
