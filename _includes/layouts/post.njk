---
layout: layouts/base.njk
---

<!-- Start Page Banner -->
<section class="page-banner blog-banner blog-single-banner">
    <div class="content-width">
        <div class="page-banner-content">
            <h1>{{ title }}</h1>
            <div class="breadcrumb">
                <a href="/">Home</a> &rsaquo; {{ title }}
            </div>
        </div>
    </div>
</section>
<!-- End Page Banner -->

<!-- Start Blog Post -->
<section class="blog-post-section">
    <div class="app-container">
        <div class="blog-layout">
            <!-- Post Content Column -->
            <div class="blog-posts-column">
                <article class="blog-post">
                    {% if image %}
                    <div class="blog-post-image">
                        <img src="{{ image }}" alt="{{ title }}">
                    </div>
                    {% endif %}

                    <div class="blog-post-content">
                        {{ content | safe }}
                    </div>

                    <div class="blog-post-footer">
                        <time datetime="{{ date | dateDisplay }}">{{ date | dateDisplay }}</time>
                        {% if categories %}
                        <span class="blog-post-footer-sep">|</span>
                        {% for cat in categories %}
                        <a href="/category/{{ cat | slugify }}/" class="blog-post-category">{{ cat }}</a>{% if not loop.last %}, {% endif %}
                        {% endfor %}
                        {% elif category %}
                        <span class="blog-post-footer-sep">|</span>
                        <a href="/category/{{ category | slugify }}/" class="blog-post-category">{{ category }}</a>
                        {% endif %}
                    </div>

                    {% set shareUrl = "https://mysteryclient.it" + page.url %}
                    {% set shareTitle = title | urlencode %}
                    <div class="blog-post-share">
                        <a href="https://www.facebook.com/sharer/sharer.php?u={{ shareUrl }}" target="_blank" rel="noopener" class="blog-share-icon" aria-label="Share on Facebook">
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
                        </a>
                        <a href="https://twitter.com/intent/tweet?url={{ shareUrl }}&text={{ shareTitle }}" target="_blank" rel="noopener" class="blog-share-icon" aria-label="Share on X">
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
                        </a>
                        <a href="https://www.linkedin.com/sharing/share-offsite/?url={{ shareUrl }}" target="_blank" rel="noopener" class="blog-share-icon" aria-label="Share on LinkedIn">
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
                        </a>
                        <a href="https://pinterest.com/pin/create/button/?url={{ shareUrl }}&description={{ shareTitle }}{% if image %}&media=https://mysteryclient.it{{ image }}{% endif %}" target="_blank" rel="noopener" class="blog-share-icon" aria-label="Pin it">
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M12.017 0C5.396 0 .029 5.367.029 11.987c0 5.079 3.158 9.417 7.618 11.162-.105-.949-.199-2.403.041-3.439.219-.937 1.406-5.957 1.406-5.957s-.359-.72-.359-1.781c0-1.668.967-2.914 2.171-2.914 1.023 0 1.518.769 1.518 1.69 0 1.029-.655 2.568-.994 3.995-.283 1.194.599 2.169 1.777 2.169 2.133 0 3.772-2.249 3.772-5.495 0-2.873-2.064-4.882-5.012-4.882-3.414 0-5.418 2.561-5.418 5.207 0 1.031.397 2.138.893 2.738a.36.36 0 01.083.345l-.333 1.36c-.053.22-.174.267-.402.161-1.499-.698-2.436-2.889-2.436-4.649 0-3.785 2.75-7.262 7.929-7.262 4.163 0 7.398 2.967 7.398 6.931 0 4.136-2.607 7.464-6.227 7.464-1.216 0-2.359-.631-2.75-1.378l-.748 2.853c-.271 1.043-1.002 2.35-1.492 3.146C9.57 23.812 10.763 24 12.017 24c6.624 0 11.99-5.367 11.99-11.988C24.007 5.367 18.641 0 12.017 0z"/></svg>
                        </a>
                        <a href="mailto:?subject={{ shareTitle }}&body={{ shareUrl }}" target="_blank"  class="blog-share-icon" aria-label="Share via Email">
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M20 4H4c-1.1 0-2 .9-2 2v12c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 4l-8 5-8-5V6l8 5 8-5v2z"/></svg>
                        </a>
                    </div>
                </article>

                {% include "related-posts.njk" %}
            </div>

            <!-- Sidebar -->
            {% include "sidebar.njk" %}
        </div>
    </div>
</section>
<!-- End Blog Post -->
