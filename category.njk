---
pagination:
  data: collections.categoryMap
  size: 1
  alias: cat
permalink: "/category/{{ cat.slug }}/"
eleventyComputed:
  title: "{{ cat.name }}"
  description: "Articoli nella categoria {{ cat.name }}"
layout: layouts/base.njk
---

<!-- Start Page Banner -->
<section class="page-banner blog-banner">
    <div class="content-width">
        <div class="page-banner-content">
            <h1>{{ cat.name }}</h1>
            <div class="breadcrumb">
                <a href="/">Home</a> &rsaquo; {{ cat.name }}
            </div>
        </div>
    </div>
</section>
<!-- End Page Banner -->

<!-- Start Category Listing -->
<section class="blog-listing-section">
    <div class="content-width">
        <div class="blog-layout">
            <!-- Blog Posts Column -->
            <div class="blog-posts-column" id="blogPostsColumn" data-per-page="5" data-total="{{ cat.posts.length }}" data-category="{{ cat.slug }}">
                {% for post in cat.posts %}
                {% if loop.index0 < 5 %}
                <div class="blog-card-category">
                    <article class="blog-card">
                        {% if post.data.image %}
                        <div class="blog-card-image">
                            <img src="{{ post.data.image }}" alt="{{ post.data.title }}">
                            <div class="blog-card-overlay">
                                <div class="blog-card-overlay-icons">
                                    <a href="{{ post.url }}" class="blog-card-overlay-icon" aria-label="View post">
                                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M10 13a5 5 0 007.54.54l3-3a5 5 0 00-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 00-7.54-.54l-3 3a5 5 0 007.07 7.07l1.71-1.71"/></svg>
                                    </a>
                                    <button class="blog-card-overlay-icon lightbox-trigger" data-image="{{ post.data.image }}" aria-label="View image">
                                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
                                    </button>
                                </div>
                                <p class="blog-card-overlay-title">{{ post.data.title }}</p>
                            </div>
                        </div>
                        {% endif %}
                        <div class="blog-card-body">
                            <h2 class="blog-card-title">
                                <a href="{{ post.url }}">{{ post.data.title }}</a>
                            </h2>
                            <p class="blog-card-excerpt">{{ post.templateContent | excerpt }} <a href="{{ post.url }}" class="blog-card-link">[...]</a></p>
                        </div>
                    </article>
                    <div class="blog-card-footer">
                        <span class="blog-card-date">{{ post.date | dateDisplay }} | {% if post.data.categories %}{% for c in post.data.categories %}<a href="/category/{{ c | slugify }}/">{{ c }}</a>{% if not loop.last %}, {% endif %}{% endfor %}{% elif post.data.category %}<a href="/category/{{ post.data.category | slugify }}/">{{ post.data.category }}</a>{% endif %}</span>
                        <a href="{{ post.url }}" class="blog-card-readmore">Read More</a>
                    </div>
                </div>
                {% endif %}
                {% endfor %}

                {% if cat.posts.length == 0 %}
                <p class="blog-empty">Nessun articolo in questa categoria.</p>
                {% endif %}

                {% if cat.posts.length > 5 %}
                <p class="blog-loading-text" id="blogLoadingText">Loading the next set of posts...</p>
                {% endif %}
            </div>

            <!-- Sidebar -->
            {% include "sidebar.njk" %}
        </div>
    </div>
</section>
<!-- End Category Listing -->
